<?xml version="1.0" encoding="utf-8"?>
<!--
    DEBUG-ONLY network security config.
    This file overrides src/main/res/xml/network_security_config.xml for debug builds,
    allowing cleartext HTTP to local emulator and development server addresses.
    It is NOT included in release builds.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host (10.0.2.2 maps to 127.0.0.1 on the host machine) -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Local development server -->
        <domain includeSubdomains="true">192.168.1.5</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
